rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasKeys(keys) {
      return request.resource.data.keys().hasAll(keys);
    }

    // --- VENDORS COLLECTION ---
    match /vendors/{userId} {
      // READ: Allow if owner
      allow get, list: if isOwner(userId);

      // CREATE: Allow if owner and valid data
      allow create: if isOwner(userId)
                    && request.resource.data.role == 'vendor'
                    && request.resource.data.email is string
                    // name and phone are required by my code but let's be slightly lenient if one is empty string, but key must exist if we use strict validation
                    // My creating code sends: email, name, phone, role, createdAt.
                    && hasKeys(['email', 'name', 'phone', 'role', 'createdAt']);

      // UPDATE: Allow if owner
      allow update: if isOwner(userId)
                    && request.resource.data.role == resource.data.role; // Immutable Role
    }

    // --- CUSTOMERS COLLECTION ---
    match /customers/{userId} {
      // READ: Allow if owner
      allow get, list: if isOwner(userId);
      
      // CREATE: Allow if owner and valid data
      // My Ecocycle code sends: email, role, createdAt + name, phone
      allow create: if isOwner(userId)
                    && request.resource.data.role == 'customer'
                    && request.resource.data.email is string;
                    // Relaxed key checks slightly to avoid breaking Google Auth flow if name/phone missing initially, 
                    // though my Google Auth code adds them.

      // UPDATE: Allow if owner
      allow update: if isOwner(userId)
                    && request.resource.data.role == resource.data.role; // Immutable Role
    }
  }
}
